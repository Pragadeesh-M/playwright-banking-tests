{
  "name": "playwright-banking-tests",
  "version": "1.0.0",
  "description": "E2E test automation suite for a demo banking application using Playwright and JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:login": "playwright test tests/login.spec.js",
    "test:accounts": "playwright test tests/accounts.spec.js",
    "test:transfer": "playwright test tests/transfer.spec.js",
    "test:billpay": "playwright test tests/billpay.spec.js",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pragadeesh-M/playwright-banking-tests.git"
  },
  "keywords": [
    "playwright",
    "e2e",
    "automation",
    "banking",
    "pom"
  ],
  "author": "Pragadeesh-M",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Pragadeesh-M/playwright-banking-tests/issues"
  },
  "homepage": "https://github.com/Pragadeesh-M/playwright-banking-tests#readme",
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
